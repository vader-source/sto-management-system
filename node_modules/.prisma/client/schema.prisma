// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model color_auto {
  id_color   Int    @id @default(autoincrement())
  code_color String @db.VarChar(50)

  autos auto[]
}

model country {
  id_country     Int    @id @default(autoincrement())
  name_country   String @db.VarChar(100)
  rating_country Float? @default(0)

  zaps      zap[]
  companies company[]
}

model company {
  id_company      Int    @id @default(autoincrement())
  name_company    String @db.VarChar(150)
  id_country_comp Int
  rating_company  Float? @default(0)

  country country @relation(fields: [id_country_comp], references: [id_country])
  zaps    zap[]
}

model STO {
  number_sto Int    @id @default(autoincrement())
  namesto    String @db.VarChar(150)
  adresssto  String @db.VarChar(255)
  hotPhone   String @db.VarChar(20)
  rating     Float? @default(0)

  autos auto[]
}

model user {
  number_user Int    @id @default(autoincrement())
  pibVod      String @db.VarChar(200)
  adressVod   String @db.VarChar(255)
  phoneNumber String @db.VarChar(20)

  autos  auto[]
  remont remont[]
}

model auto {
  number_avto Int     @id @default(autoincrement())
  color_id    Int
  id_STO      Int
  mark        String  @db.VarChar(100)
  VIN_code    String  @unique @db.VarChar(17)
  photo       String? @db.VarChar(500)
  id_vod      Int

  color color_auto @relation(fields: [color_id], references: [id_color])
  sto   STO        @relation(fields: [id_STO], references: [number_sto])
  user  user       @relation(fields: [id_vod], references: [number_user])

  remont remont[]
}

model machenist {
  number_mach Int     @id @default(autoincrement())
  pib         String  @db.VarChar(200)
  adress      String  @db.VarChar(255)
  telephone   String  @db.VarChar(20)
  clav        String? @db.VarChar(100)
  rate        Float?  @default(0)
  photo       String? @db.VarChar(500)

  remont remont[]
}

model zap {
  id_zap         Int    @id @default(autoincrement())
  name_zap       String @db.VarChar(200)
  country_id_zap Int
  company_id_zap Int
  price          Float  @default(0)
  count_now      Int    @default(0)

  country country @relation(fields: [country_id_zap], references: [id_country])
  company company @relation(fields: [company_id_zap], references: [id_company])

  remont    remont[]
  zamov_zap zamov_zap[]
}

model zamov_zap {
  id_zap            Int       @id @default(autoincrement())
  count_order       Int       @default(1)
  name_order        String    @db.VarChar(200)
  id_man            Int
  description_Order String?   @db.Text
  price_order       Float     @default(0)
  dataStartOrder    DateTime? @db.Date
  dataTakeOrder     DateTime? @db.Date
  Status            String    @default("pending") @db.VarChar(50)

  zap zap @relation(fields: [id_zap], references: [id_zap])
}

model remont {
  id_rem         Int       @id @default(autoincrement())
  id_Avto        Int
  desciption     String?   @db.Text
  price          Float     @default(0)
  timestart      DateTime? @db.Date
  dataend        DateTime? @db.Date
  Id_mech        Int
  id_zapch       Int?
  zap            Int?
  rating_current Float?    @default(0)
  id_vod         Int

  auto      auto      @relation(fields: [id_Avto], references: [number_avto])
  machenist machenist @relation(fields: [Id_mech], references: [number_mach])
  zap_part  zap?      @relation(fields: [zap], references: [id_zap])
  user      user      @relation(fields: [id_vod], references: [number_user])
}
